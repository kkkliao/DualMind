# DualMind server
DUALMIND_HOST=127.0.0.1
DUALMIND_PORT=3000

# Optional explicit CLI paths. Leave empty to auto-detect from PATH and common install locations.
OPENCLAW_BIN=
HERMES_BIN=

# Notes:
# - DualMind connects to OpenClaw and Hermes as agent systems.
# - The underlying model/provider is configured inside OpenClaw and Hermes themselves.
# - Do not put model provider API keys here unless a future integration explicitly requires it.
